# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development                  # development | production | test
LOG_LEVEL=info                        # debug | info | warn | error
PORT=3000

# ── Database / Cache ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://sellabot:sellabot@localhost:5432/sellabot
REDIS_URL=redis://localhost:6379

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# ── LLM provider ─────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Shopee Open Platform (partner-level, never per-shop) ──────────────────────
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REGION=SG                      # SG | MY | TH | PH | ID | TW | VN | BR | MX | CO | CL
SHOPEE_REDIRECT_URL=http://localhost:3000/auth/shopee/callback
SHOPEE_ENV=test                       # test | live

# ── Future platforms (uncomment when adapters land) ───────────────────────────
# LAZADA_APP_KEY=
# LAZADA_APP_SECRET=
# TIKTOKSHOP_APP_KEY=
# TIKTOKSHOP_APP_SECRET=
